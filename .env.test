# Overrides for integration tests. Medusa's loadEnv merges .env + .env.test,
# so this only needs the variables the test harness (@medusajs/test-utils)
# reads directly (it consumes DB_USERNAME/PASSWORD/HOST rather than
# DATABASE_URL). The harness provisions and drops its own throwaway DB
# per run via pg-god; prod data is never touched.
DB_USERNAME=medusa
DB_PASSWORD=medusa123
DB_HOST=localhost
